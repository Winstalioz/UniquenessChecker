<Window x:Class="UniquenessChecker.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Администратор — УникДос"
        Height="680" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource LightBgBrush}">

    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1F5287"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== БОКОВАЯ ПАНЕЛЬ ===== -->
        <Border Grid.Column="0" Background="#2E74B5">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="🔍 УникДос" FontSize="18" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock x:Name="UserNameText" FontSize="11" Foreground="#BDD7EE"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <Button x:Name="BtnUsers"     Content="👤  Пользователи" Tag="users"
                        Style="{StaticResource NavButton}" Click="OnNavClick"/>
                <Button x:Name="BtnDocs"      Content="📄  Документы"    Tag="docs"
                        Style="{StaticResource NavButton}" Click="OnNavClick"/>
                <Button x:Name="BtnSources"   Content="🔗  Заимствования" Tag="sources"
                        Style="{StaticResource NavButton}" Click="OnNavClick"/>
                <Button x:Name="BtnSQL"       Content="⚙  SQL-консоль"   Tag="sql"
                        Style="{StaticResource NavButton}" Click="OnNavClick"/>
                <Button x:Name="BtnStats"     Content="📊  Статистика"   Tag="stats"
                        Style="{StaticResource NavButton}" Click="OnNavClick"/>

                <Button Content="🚪  Выход" Margin="12,40,12,0"
                        Background="#1F5287" Foreground="White"
                        BorderThickness="0" Padding="10,8" Cursor="Hand"
                        Click="OnLogout"/>
            </StackPanel>
        </Border>

        <!-- ===== КОНТЕНТ ===== -->
        <Grid Grid.Column="1" Margin="24">

            <!-- Пользователи -->
            <StackPanel x:Name="PanelUsers" Visibility="Visible">
                <TextBlock Text="Управление пользователями" Style="{StaticResource SectionHeader}"/>

                <!-- Форма добавления -->
                <Border Background="White" BorderBrush="#DDD" BorderThickness="1"
                        CornerRadius="6" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="NewLogin"    Text="Логин"     Margin="0,0,8,0" Style="{StaticResource InputField}"/>
                        <TextBox Grid.Column="1" x:Name="NewFullName" Text="Имя"       Margin="0,0,8,0" Style="{StaticResource InputField}"/>
                        <TextBox Grid.Column="2" x:Name="NewEmail"    Text="E-mail"    Margin="0,0,8,0" Style="{StaticResource InputField}"/>
                        <ComboBox Grid.Column="3" x:Name="NewRole"    Margin="0,0,8,0" FontSize="14"/>
                        <Button  Grid.Column="4" Content="Добавить"   Style="{StaticResource PrimaryButton}" Click="OnAddUser"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          BorderBrush="#DDD" BorderThickness="1" Background="White"
                          RowBackground="White" AlternatingRowBackground="#F9FBFF"
                          GridLinesVisibility="Horizontal" Height="420">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"       Binding="{Binding UserId}"    Width="50"/>
                        <DataGridTextColumn Header="Логин"    Binding="{Binding Login}"     Width="150"/>
                        <DataGridTextColumn Header="Имя"      Binding="{Binding FullName}"  Width="200"/>
                        <DataGridTextColumn Header="E-mail"   Binding="{Binding Email}"     Width="180"/>
                        <DataGridTextColumn Header="Роль"     Binding="{Binding RoleName}"  Width="130"/>
                        <DataGridTextColumn Header="Создан"   Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="110"/>
                        <DataGridTemplateColumn Header="Действия" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Удалить" Style="{StaticResource DangerButton}"
                                            Padding="8,4" Click="OnDeleteUser" Tag="{Binding UserId}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <!-- Документы -->
            <StackPanel x:Name="PanelDocs" Visibility="Collapsed">
                <TextBlock Text="Все документы" Style="{StaticResource SectionHeader}"/>
                <DataGrid x:Name="DocsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          BorderBrush="#DDD" BorderThickness="1" Background="White"
                          RowBackground="White" AlternatingRowBackground="#F9FBFF"
                          GridLinesVisibility="Horizontal" Height="520"
                          SelectionChanged="OnDocSelected">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"          Binding="{Binding DocumentId}"        Width="50"/>
                        <DataGridTextColumn Header="Файл"        Binding="{Binding FileName}"          Width="200"/>
                        <DataGridTextColumn Header="Размер, КБ"  Binding="{Binding FileSizeKb}"        Width="90"/>
                        <DataGridTextColumn Header="Дата"        Binding="{Binding UploadDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Уникальность" Binding="{Binding UniquenessDisplay}" Width="110"/>
                        <DataGridTextColumn Header="Статус"      Binding="{Binding StatusDisplay}"     Width="110"/>
                        <DataGridTextColumn Header="Автор"       Binding="{Binding AuthorName}"        Width="*"/>
                        <DataGridTemplateColumn Header="" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Отчёт" Style="{StaticResource PrimaryButton}"
                                            Padding="8,4" Click="OnViewReport" Tag="{Binding DocumentId}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <!-- Заимствования -->
            <StackPanel x:Name="PanelSources" Visibility="Collapsed">
                <TextBlock Text="Топ источников заимствования" Style="{StaticResource SectionHeader}"/>
                <DataGrid x:Name="SourcesGrid" AutoGenerateColumns="True" IsReadOnly="True"
                          BorderBrush="#DDD" BorderThickness="1" Background="White"
                          RowBackground="White" AlternatingRowBackground="#F9FBFF"
                          Height="520"/>
            </StackPanel>

            <!-- SQL-консоль -->
            <Grid x:Name="PanelSQL" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="SQL-консоль" Style="{StaticResource SectionHeader}"/>
                <TextBox   Grid.Row="1" x:Name="SqlInput"
                           FontFamily="Courier New" FontSize="13"
                           Background="#1E1E1E" Foreground="#D4D4D4"
                           AcceptsReturn="True" AcceptsTab="True"
                           VerticalScrollBarVisibility="Auto"
                           Padding="12" BorderThickness="0"
                           Text="-- Пример запроса:&#10;SELECT * FROM vw_DocumentsWithAuthors ORDER BY upload_date DESC;"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,8">
                    <Button Content="▶  Выполнить" Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" Click="OnExecuteSql"/>
                    <Button Content="Очистить" Background="#777" Foreground="White"
                            BorderThickness="0" Padding="12,8" Cursor="Hand"
                            Click="OnClearSql"/>
                    <TextBlock x:Name="SqlStatus" Margin="12,0,0,0"
                               VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
                <DataGrid Grid.Row="3" x:Name="SqlResultGrid"
                          AutoGenerateColumns="True" IsReadOnly="True"
                          BorderBrush="#DDD" BorderThickness="1" Background="White"
                          RowBackground="White" AlternatingRowBackground="#F9FBFF"/>
            </Grid>

            <!-- Статистика -->
            <StackPanel x:Name="PanelStats" Visibility="Collapsed">
                <TextBlock Text="Статистика системы" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="По уровням уникальности" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <DataGrid x:Name="StatsRangeGrid" AutoGenerateColumns="True" IsReadOnly="True"
                          BorderBrush="#DDD" BorderThickness="1" Background="White"
                          Height="120" Margin="0,0,0,20"/>

                <TextBlock Text="Статистика по пользователям" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <DataGrid x:Name="StatsUserGrid" AutoGenerateColumns="True" IsReadOnly="True"
                          BorderBrush="#DDD" BorderThickness="1" Background="White"
                          Height="300"/>
            </StackPanel>
        </Grid>
    </Grid>


</Window>
