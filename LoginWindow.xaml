<Window x:Class="UniquenessChecker.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему — УникДос"
        Height="420" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EAF4FB" Offset="0"/>
            <GradientStop Color="#F5F9FD" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Логотип / заголовок -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,28">
            <TextBlock Text="🔍" FontSize="42" HorizontalAlignment="Center"/>
            <TextBlock Text="УникДос" FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Проверка уникальности текстовых работ"
                       FontSize="11" Foreground="#777"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Логин -->
        <TextBlock Grid.Row="1" Text="Логин" FontSize="13" Margin="0,0,0,4"/>
        <TextBox   Grid.Row="2" x:Name="LoginBox" Style="{StaticResource InputField}"
                   Margin="0,0,0,14" KeyDown="OnKeyDown"/>

        <!-- Пароль -->
        <TextBlock Grid.Row="3" Text="Пароль" FontSize="13" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="4" x:Name="PasswordBox"
                     Padding="8,6" FontSize="14" BorderBrush="#CCC" BorderThickness="1"
                     Margin="0,0,0,8" KeyDown="OnKeyDown"/>

        <!-- Ошибка -->
        <TextBlock Grid.Row="5" x:Name="ErrorText" Foreground="Red"
                   FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                   Visibility="Collapsed"/>

        <!-- Кнопка -->
        <Button Grid.Row="6" Content="Войти" Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Stretch" Height="40"
                Click="OnLoginClick"/>
    </Grid>
</Window>
